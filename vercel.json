{
    "version": 2,
    "name": "printwork-web",
    "regions": ["sin1"],
    "builds": [
        { "src": "server.js", "use": "@vercel/node" },
        { "src": "*.html", "use": "@vercel/static" },
        { "src": "*.{png,jpg,jpeg,ico,svg,mp4,webm,pdf,css,js}", "use": "@vercel/static" },
        { "src": "media/*", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "server.js" },
        { "src": "/health", "dest": "server.js" },
        { "src": "/admin", "dest": "server.js" },
        { "src": "/(.*)", "dest": "/$1" }
    ]
}